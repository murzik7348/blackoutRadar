{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BlackoutSchedule",
  "type": "object",
  "properties": {
    "city": {
      "type": [
        "string",
        "null"
      ]
    },
    "oblast": {
      "type": [
        "string",
        "null"
      ]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "queues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "queue": {
            "type": "integer",
            "minimum": 1
          },
          "intervals": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "maxItems": 2
            }
          }
        },
        "required": [
          "queue",
          "intervals"
        ]
      }
    },
    "source_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "raw_text": {
      "type": "string"
    }
  },
  "required": [
    "date",
    "queues",
    "raw_text"
  ]
}